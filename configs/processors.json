{
  "processors": [
    {
      "name": "OpenClaw",
      "filename": "openclaw_logs.csv",
      "timestamp_columns": ["Timestamp"],
      "source_timezone": "UTC",
      "target_timezone": null,
      "column_map": {
        "venue_area":         "Project",
        "terminal_id":        "SessionID",
        "reference_id":       "ActionID",
        "auth_code":          "ToolUsed",
        "tender_type":        "Model",
        "amount":             "ComputeCost",
        "settlement_status":  "TaskStatus",
        "batch_id":           "Deployment"
      },
      "constants": {
        "transaction_type": "ACTION"
      }
    },
    {
      "name": "Claude",
      "filename": "claude_audit.csv",
      "timestamp_columns": ["Created_At"],
      "source_timezone": "UTC",
      "target_timezone": null,
      "column_map": {
        "venue_area":         "App_Name",
        "terminal_id":        "Conversation_Root",
        "reference_id":       "Message_UUID",
        "auth_code":          "Auth_Key_ID",
        "transaction_type":   "Turn_Type",
        "amount":             "Token_Price",
        "settlement_status":  "State",
        "batch_id":           "Org_ID"
      },
      "constants": {
        "tender_type": "ANTHROPIC"
      }
    },
    {
      "name": "LangChain",
      "filename": "langchain_trace.csv",
      "timestamp_columns": ["StartTime"],
      "source_timezone": null,
      "target_timezone": null,
      "column_map": {
        "venue_area":         "TracePath",
        "terminal_id":        "RunID",
        "reference_id":       "StepID",
        "amount":             "EstimatedCost",
        "settlement_status":  "CompletionStatus",
        "batch_id":           "ProjectID"
      },
      "constants": {
        "auth_code":          "LC_AUTH",
        "tender_type":        "LC_TOKEN",
        "transaction_type":   "CHAIN_STEP"
      }
    },
    {
      "name": "OpenAI",
      "filename": "openai_usage.csv",
      "timestamp_columns": ["RequestTime"],
      "source_timezone": "UTC",
      "target_timezone": null,
      "column_map": {
        "venue_area":         "AppID",
        "terminal_id":        "UserSID",
        "reference_id":       "ReqID",
        "auth_code":          "ApiKeyLast4",
        "tender_type":        "ModelName",
        "transaction_type":   "CallType",
        "amount":             "PriceUSD",
        "settlement_status":  "ResponseCode",
        "batch_id":           "BillingCycle"
      },
      "constants": {}
    }
  ]
}
