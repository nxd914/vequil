# Vequil environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real key.

# OpenAI API key — get yours at https://platform.openai.com/api-keys
# When set, the Agentic Recon Engine uses gpt-4o-mini for real diagnoses.
# When unset, it falls back to the high-quality built-in mock.
OPENAI_API_KEY=

# Dashboard API key — protects the /api/* endpoints.
# Set any strong random string here, e.g.: openssl rand -hex 32
# Leave blank to run in open dev mode (no auth).
DASHBOARD_API_KEY=
